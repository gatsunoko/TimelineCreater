# Rails Production Environment Variables Example
# コピーして `.env` ファイルを作成し、適切な値を設定してください

# Railsの秘密鍵（任意の長いランダム文字列、または `openssl rand -hex 64` で生成）
SECRET_KEY_BASE=your_secure_production_secret_key_base_here

# PostgreSQLのパスワード（強固な文字列に変更してください）
DATABASE_PASSWORD=your_secure_db_password_here

# Google OAuth2 認証情報
# Google Cloud Console (https://console.cloud.google.com/) で取得してください
# 1. プロジェクトを作成
# 2. 「APIとサービス」→「認証情報」→「認証情報を作成」→「OAuthクライアントID」
# 3. アプリケーションの種類: ウェブアプリケーション
# 4. 承認済みのリダイレクト URI: http://localhost/users/auth/google_oauth2/callback (開発時)
#    本番環境: https://your-domain.com/users/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
