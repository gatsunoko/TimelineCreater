<% content_for :page_title, "ログイン" %>
<% content_for :header_label, "LOGIN" %>

<section class="section auth-panel">
  <h2 class="section-title">ログイン</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="form-grid">
      <div class="form-full form-field">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-full">
          <label>
            <%= f.check_box :remember_me %>
            ログイン状態を保持する
          </label>
        </div>
      <% end %>

      <div class="form-actions">
        <%= link_to "新規登録", new_registration_path(resource_name), class: "btn btn-secondary" %>
        <%= f.submit "ログイン", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</section>
