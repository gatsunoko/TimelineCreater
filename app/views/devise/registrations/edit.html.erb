<% content_for :page_title, "プロフィール編集" %>
<% content_for :header_label, "SETTINGS" %>

<section class="section auth-panel">
  <h2 class="section-title">プロフィール編集</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <% if resource.errors.any? %>
      <div class="flash alert"><%= resource.errors.full_messages.join(" / ") %></div>
    <% end %>

    <div class="form-grid">
      <div class="form-full form-field">
        <%= f.label :name, "名前" %>
        <%= f.text_field :name, autofocus: true, placeholder: "歴史 太郎" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autocomplete: "email" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="form-full text-muted" style="font-size: var(--font-size-xs);">
          現在、次のメールアドレスの確認待ちです: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="form-full form-field">
        <%= f.label :password, "新しいパスワード (変更しない場合は空欄)" %>
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :password_confirmation, "新しいパスワード確認" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :current_password, "現在のパスワード (パスワードを変更する場合のみ入力)" %>
        <%= f.password_field :current_password, autocomplete: "new-password", value: "" %>
      </div>

      <div class="form-actions">
        <%= link_to "戻る", :back, class: "btn btn-secondary" %>
        <%= f.submit "更新する", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</section>
