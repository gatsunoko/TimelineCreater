<% content_for :page_title, "新規登録" %>
<% content_for :header_label, "SIGN UP" %>

<section class="section auth-panel">
  <h2 class="section-title">新規登録</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <% if resource.errors.any? %>
      <div class="flash alert"><%= resource.errors.full_messages.join(" / ") %></div>
    <% end %>

    <div class="form-grid">
      <div class="form-full form-field">
        <%= f.label :name, "名前" %>
        <%= f.text_field :name, autofocus: true, placeholder: "歴史 太郎" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autocomplete: "email" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div class="form-full form-field">
        <%= f.label :password_confirmation, "パスワード確認" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= link_to "ログイン", new_session_path(resource_name), class: "btn btn-secondary" %>
        <%= f.submit "登録", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</section>
