<% content_for :page_title, "マイ年表" %>
<% content_for :header_label, "TIMELINES" %>

<section class="section">
  <div class="toolbar">
    <h2 class="section-title" style="margin-bottom:0;">自分の年表</h2>
    <%= link_to "新しい年表を作成", new_timeline_path, class: "btn btn-primary" %>
  </div>

  <% if @timelines.any? %>
    <%= render "timeline_list", timelines: @timelines, owner_controls: true, show_owner: false %>
    <% if @timelines_scope.count > 5 %>
      <div class="more-link">
        <%= link_to "もっと見る", mine_timelines_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  <% else %>
    <div class="empty-message">まだ年表がありません。</div>
  <% end %>
</section>

<section class="section">
  <h2 class="section-title">公開年表</h2>

  <% if @public_timelines.any? %>
    <%= render "timeline_list", timelines: @public_timelines, owner_controls: false, show_owner: true %>
    <% if @public_timelines_scope.count > 5 %>
      <div class="more-link">
        <%= link_to "もっと見る", public_index_timelines_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  <% else %>
    <div class="empty-message">他のユーザーの公開年表はまだありません。</div>
  <% end %>
</section>
